# Supabase Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# Your Supabase Project URL
# Get this from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase Anon Key (Public Key)
# Get this from: Supabase Dashboard → Settings → API → Project API Keys → anon
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Service Role Key (NEVER expose in frontend!)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin Credentials for testing
ADMIN_EMAIL=admin@portfolio.dev
ADMIN_PASSWORD=Admin123!Secure
